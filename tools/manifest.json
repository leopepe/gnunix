    "$note": "Compile-time hardening per ADR-011. The native_* sets are exported by stage 03b onwards (final native build); the cross_* sets are exported by stages 01-02 (cross-toolchain + temp-tools). Per-package exclusions are merged in by lib/hardening.sh:hardening_export. CFLAGS use space-separated tokens so the helper can split on whitespace; never embed spaces inside a token.",
    "native_cflags":   "-O2 -U_FORTIFY_SOURCE -D_FORTIFY_SOURCE=3 -fstack-protector-strong -fstack-clash-protection -fPIE -mbranch-protection=standard -fno-strict-overflow -fno-delete-null-pointer-checks -fno-strict-aliasing -ftrivial-auto-var-init=zero -Wformat -Wformat=2 -Werror=format-security",
    "native_cxxflags_extra": "-D_GLIBCXX_ASSERTIONS",
    "native_ldflags":  "-Wl,-z,relro -Wl,-z,now -Wl,-z,noexecstack -Wl,--as-needed",
    "cross_cflags":    "-O2",
    "cross_ldflags":   "-Wl,-z,relro -Wl,-z,now",
    "exclude": {
      "$note": "Per-package strip list. Values: a list of individual flag tokens to drop from CFLAGS+CXXFLAGS+LDFLAGS, OR the special sentinel ['ALL'] to drop every hardening flag for that package (kernel, GRUB).",
      "glibc":    ["-D_FORTIFY_SOURCE=3", "-fstack-protector-strong", "-fPIE", "-pie", "-Werror=format-security"],
      "linux":    ["ALL"],
      "kernel":   ["ALL"],
      "gcc":      ["-pie", "-fPIE", "-Werror=format-security"],
      "grub":     ["-fPIE", "-pie", "-fstack-protector-strong", "-fstack-clash-protection", "-mbranch-protection=standard", "-Werror=format-security"],
      "binutils": ["-D_FORTIFY_SOURCE=3", "-Werror=format-security"],
      "bash":     ["-ftrivial-auto-var-init=zero"],
      "gettext":  ["-ftrivial-auto-var-init=zero"]
    }
  }
}
