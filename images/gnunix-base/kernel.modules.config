# Kernel config fragment for gnunix-base (aarch64) — module-first overrides.
# Per ADR-012. Applied AFTER kernel.config; later wins via olddefconfig.
#
# Rule: anything in here MUST be safe to load post-init.
# Boot-critical drivers (virtio-blk, ext4, EFI stub, virtio-pci, virtio-console)
# stay =y in kernel.config — they have to be live before /sbin/init runs.
#
# Auto-loading: rc.S → udevadm trigger --action=add walks /sys and
# modprobes the matching MODALIAS for each present device. The modules
# below all expose proper MODALIAS entries in their respective bus aliases.

# --- Network ---
# Kept built-in (=y in kernel.config). Switching it to =m broke boot in
# the initial module-first run because eudev wasn't loading the module
# in time for rc.network to find an interface. Revisit after we've
# verified eudev's coldplug path end-to-end.
#CONFIG_VIRTIO_NET=m

# --- Memory ballooning (cosmetic; loaded whenever) ---
CONFIG_VIRTIO_BALLOON=m

# --- Input devices (needed when sway opens evdev devices) ---
CONFIG_VIRTIO_INPUT=m

# --- Alternative virtio bus (ARM virt machines without PCI) ---
CONFIG_VIRTIO_MMIO=m

# --- GPU + display (only at compositor start) ---
CONFIG_DRM=m
CONFIG_DRM_VIRTIO_GPU=m
CONFIG_FB=m
CONFIG_FRAMEBUFFER_CONSOLE=m

# --- Optional filesystems (loaded by `mount -a` from rc.S as needed) ---
CONFIG_VFAT_FS=m
CONFIG_NLS_CODEPAGE_437=m
CONFIG_NLS_ISO8859_1=m
CONFIG_NLS_UTF8=m
