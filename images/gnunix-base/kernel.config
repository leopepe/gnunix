# Kernel config fragment for gnunix-base (aarch64, Apple Silicon under Tart).
# Applied on top of `make ARCH=arm64 defconfig` via olddefconfig.
# Only overrides — the defconfig is otherwise unchanged.

# --- Virtualization.framework guest essentials ---
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_INPUT=y
CONFIG_VIRTIO_MMIO=y

# --- Graphics (virtio-gpu, used by the Wayland compositor in Phase 4) ---
CONFIG_DRM=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# --- Filesystems ---
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_VFAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_UTF8=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# --- EFI boot (ADR-006: GRUB EFI) ---
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_VARS=y
CONFIG_EFIVAR_FS=y

# --- Required by Nix sandbox builds (ADR-003) ---
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_MEMCG=y
CONFIG_NAMESPACES=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# --- Required by elogind (ADR-002) ---
CONFIG_INOTIFY_USER=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EPOLL=y
CONFIG_NET=y
CONFIG_UNIX=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

# --- Networking essentials ---
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y

# --- Misc ---
CONFIG_PRINTK=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_BLK_DEV_INITRD=n   # Tart can boot a kernel directly; no initrd in this base
