{
  "layer": "top",
  "position": "top",
  "height": 26,
  "modules-left":   ["hyprland/workspaces", "hyprland/submap"],
  "modules-center": ["hyprland/window"],
  "modules-right":  ["cpu", "memory", "clock"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{id}"
  },
  "hyprland/submap": {
    "format": "{}"
  },
  "hyprland/window": {
    "max-length": 80
  },
  "cpu": {
    "format": "CPU {usage}%",
    "interval": 5
  },
  "memory": {
    "format": "MEM {used:0.1f}G",
    "interval": 5
  },
  "clock": {
    "format": "{:%Y-%m-%d %H:%M:%S}",
    "interval": 1
  }
}
