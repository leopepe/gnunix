{
  "layer": "top",
  "position": "top",
  "height": 26,
  "modules-left":   ["sway/workspaces", "sway/mode"],
  "modules-center": ["sway/window"],
  "modules-right":  ["cpu", "memory", "clock"],

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true
  },
  "sway/window": {
    "max-length": 80
  },
  "cpu": {
    "format": "CPU {usage}%",
    "interval": 5
  },
  "memory": {
    "format": "MEM {used:0.1f}G",
    "interval": 5
  },
  "clock": {
    "format": "{:%Y-%m-%d %H:%M:%S}",
    "interval": 1
  }
}
