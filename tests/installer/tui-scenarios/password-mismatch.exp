#!/usr/bin/env expect
# tests/installer/tui-scenarios/password-mismatch.exp
#
# Verify the password-confirmation loop: enter a wrong re-entry first,
# see the "Passwords do not match" msgbox, then enter the correct pair.
# The choices file should reflect the FINAL (matching) password — not a
# silent acceptance of the first attempt.
#
# Expected choices file:
#   TARGET_DISK=/dev/vda
#   PROFILE=minimal
#   HOSTNAME=gnunix
#   USERNAME=user
#   PASSWORD=correct-on-retry

source [file join [file dirname $argv0] _lib.exp]

start_installer

await_screen "Welcome to the GNUnix installer"
press_enter

await_screen "Target disk"
press_enter

# Minimal so we skip the network warning + compositor screens.
await_screen "Edition:"
send -s -- "\033\[A"
send -s -- " "
send -s -- "\t\r"

await_screen "Hostname:"
press_enter

await_screen "lowercase, no spaces"
press_enter

# First attempt: wrong re-entry → mismatch msgbox.
await_screen "Set password for"
type_text "first-attempt"

await_screen "Re-enter password"
type_text "DIFFERENT-VALUE"

await_screen "Passwords do not match"
press_enter

# Second attempt: matching pair.
await_screen "Set password for"
type_text "correct-on-retry"

await_screen "Re-enter password"
type_text "correct-on-retry"

await_screen "Ready to install"
press_enter

expect eof
